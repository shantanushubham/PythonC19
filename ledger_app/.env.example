# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
# Options:
#   ledger_project.settings.local       (LOCAL / developer laptop)
#   ledger_project.settings.production  (STG / PROD)
DJANGO_SETTINGS_MODULE=ledger_project.settings.local

SECRET_KEY=replace-with-a-strong-random-key
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=ledger_db
DB_USER=ledger_user
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-jwt-secret
JWT_ALGORITHM=HS256

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS (required for production, optional for local) ────────────────────────
# Local example:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
