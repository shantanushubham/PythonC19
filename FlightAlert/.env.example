# Django
DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://flightalert:flightalert@localhost:5432/flightalert
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT (optional — defaults shown)
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Brevo transactional email
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=FlightAlert

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Alert check interval in seconds (optional — default 900 = 15 min)
ALERT_CHECK_INTERVAL_SECONDS=900

# Price fetcher: "mock" for local dev, replace with real key when integrating a live API
FLIGHT_PRICE_FETCHER=mock
